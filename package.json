{
  "name": "ytgrab",
  "version": "0.1.0",
  "description": "A Node.js YouTube video downloader ported from yt-dlp",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ytgrab": "bin/ytgrab.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "youtube",
    "video",
    "download",
    "extractor",
    "stream"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "astring": "^1.9.0",
    "got-scraping": "^4.2.1",
    "meriyah": "^6.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
